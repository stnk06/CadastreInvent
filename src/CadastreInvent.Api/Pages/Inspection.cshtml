@page
@model CadastreInvent.Api.Pages.InspectionModel
@{
    ViewData["Title"] = "Полевые инспекции";
    ViewData["ActivePage"] = "Inspection";
}

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/registry-modals.css" asp-append-version="true" />

@if (!Model.IsDispatcher)
{
    <div class="page-header">
        <div>
            <h1 class="page-title">Полевые инспекции (АРМ Инспектора)</h1>
            <p class="page-subtitle">Внутренняя маршрутизация и доступ к мобильному API</p>
        </div>
    </div>

    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 40px; text-align: center; margin-top: 24px; box-shadow: var(--shadow-card);">
        <i data-lucide="smartphone" style="width: 64px; height: 64px; color: #3b82f6; margin-bottom: 20px;"></i>
        <h2 style="font-size: 1.5rem; margin-top: 0; margin-bottom: 12px; color: #0f172a;">Доступ ограничен веб-клиентом</h2>
        <p style="color: #64748b; font-size: 1.05rem; max-width: 500px; margin: 0 auto 24px auto; line-height: 1.6;">
            Вы авторизованы под учетной записью <strong>Полевого инспектора</strong>. Для выполнения обследований, фотофиксации и сбора GPS-координат вам необходимо использовать специализированное мобильное приложение (Android/iOS), подключенное к нашему API.
        </p>
        <div style="display: flex; gap: 12px; justify-content: center;">
            <a href="/InspectionHelp" class="btn-outline"><i data-lucide="help-circle"></i> Изучить регламент</a>
            <a href="/" class="btn-primary"><i data-lucide="home"></i> На главную</a>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (window.lucide) window.lucide.createIcons();
        });
    </script>
}
else
{
    <link rel="stylesheet" href="~/css/inspection-dispatcher.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <div class="page-header" style="margin-bottom: 0;">
        <div>
            <h1 class="page-title">Диспетчеризация инспекций</h1>
            <p class="page-subtitle">Координация полевых выездов и верификация результатов мониторинга в режиме Real-Time</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a href="/InspectionHelp" class="btn-outline">
                <i data-lucide="help-circle"></i> Регламент
            </a>
            <button class="btn-primary" onclick="document.getElementById('modal-create').classList.add('open')">
                <i data-lucide="plus"></i> Сформировать ордер
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info" style="margin-top: 24px; border-radius: 12px; padding: 16px; @(Model.StatusMessage.Contains("Ошибка") || Model.StatusMessage.Contains("Сбой") || Model.StatusMessage.Contains("отклонен") ? "background: #fef2f2; color: #991b1b; border: 1px solid #fecaca;" : "background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0;")">
            <i data-lucide="@(Model.StatusMessage.Contains("Ошибка") || Model.StatusMessage.Contains("Сбой") || Model.StatusMessage.Contains("отклонен") ? "alert-triangle" : "check-circle")" style="width: 20px; height: 20px; display: inline-block; vertical-align: middle; margin-right: 10px;"></i>
            <span style="vertical-align: middle; font-weight: 500;">@Model.StatusMessage</span>
        </div>
    }

    <div class="dispatch-container">
        <aside class="dispatch-sidebar">
            <div class="dispatch-header">
                <div class="dispatch-title">
                    <i data-lucide="radar" style="color: #3b82f6;"></i> Реестр ордеров
                    <span id="socket-status" style="margin-left: auto; width: 12px; height: 12px; background: #94a3b8; border-radius: 50%; display: inline-block; box-shadow: 0 0 8px rgba(0,0,0,0.15);" title="Статус WebSockets"></span>
                </div>
                <div class="task-filters">
                    <button class="task-filter-btn active" onclick="window.filterTasks('all', this)">Все</button>
                    <button class="task-filter-btn" onclick="window.filterTasks('Assigned', this)">Назначенные</button>
                    <button class="task-filter-btn" onclick="window.filterTasks('InProgress', this)">В работе</button>
                    <button class="task-filter-btn" onclick="window.filterTasks('Completed', this)" style="border-color: #10b981; color: #059669; background: #ecfdf5;">Ожидают проверки</button>
                </div>
            </div>
            <div class="task-list" id="task-list-container">
            </div>
        </aside>

        <div class="dispatch-map-area">
            <div id="dispatch-map"></div>

            <div class="validation-panel" id="validation-panel">
                <div class="vp-header">
                    <div class="vp-title"><i data-lucide="shield-check" style="color: #10b981;"></i> Панель верификации</div>
                    <button class="vp-close" onclick="window.closeValidationPanel()"><i data-lucide="x"></i></button>
                </div>
                <div class="vp-content" id="vp-content">
                </div>
                <div class="vp-footer" id="vp-footer" style="display: none;">
                    <div style="display: flex; gap: 12px; width: 100%;">
                        <button type="button" onclick="window.processVerification('rework')" class="vp-btn vp-btn-reject"><i data-lucide="refresh-cw" style="width: 18px;"></i> На доработку</button>
                        <button type="button" onclick="window.processVerification('approve')" class="vp-btn vp-btn-approve"><i data-lucide="check-circle" style="width: 18px;"></i> Утвердить</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- МОДАЛЬНОЕ ОКНО СОЗДАНИЯ ОРДЕРА -->
    <div id="modal-create" class="modal-overlay">
        <div class="modal-container">
            <form method="post" asp-page-handler="CreateTask" onsubmit="return window.validateInspectionForm()">
                <div style="padding: 24px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; background: #f8fafc; border-radius: 16px 16px 0 0;">
                    <h3 style="margin: 0; font-size: 1.2rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px;">
                        <i data-lucide="file-plus" style="color: #3b82f6;"></i> Новый ордер инспекции
                    </h3>
                    <button type="button" style="background: none; border: none; cursor: pointer; color: #64748b; padding: 4px;" onclick="document.getElementById('modal-create').classList.remove('open')">
                        <i data-lucide="x"></i>
                    </button>
                </div>
                <div style="padding: 24px; display: flex; flex-direction: column; gap: 20px;">

                    <div class="form-group" style="margin: 0;">
                        <label class="form-label" style="display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 8px;">Целевой участок (Контур ГИС)</label>
                        <input type="hidden" asp-for="CreateTaskInput.SpatialUnitId" id="wiz-spatial-id" />
                        <div class="lookup-wrapper">
                            <input type="text" id="wiz-spatial-text" class="lookup-input" readonly placeholder="Нажмите для вызова справочника..." onclick="openDictionary('/api/inspection/spatial-units/search', 'wiz-spatial-id', 'wiz-spatial-text', 'Системный справочник: Пространственные контуры')" style="border-radius: 8px; border-color: #cbd5e1; cursor: pointer;" />
                            <button type="button" class="lookup-btn" onclick="openDictionary('/api/inspection/spatial-units/search', 'wiz-spatial-id', 'wiz-spatial-text', 'Системный справочник: Пространственные контуры')" style="border-radius: 0 8px 8px 0;"><i data-lucide="search" style="width: 16px;"></i></button>
                        </div>
                    </div>

                    <div style="margin: 0;">
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 8px;">Исполнитель (Инспектор)</label>
                        <select asp-for="CreateTaskInput.InspectorId" class="form-control" required style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; outline: none; background: #ffffff;">
                            <option value="">-- Назначить инспектора --</option>
                            @foreach (var i in Model.AvailableInspectors)
                            {
                                <option value="@i.Key">@i.Value</option>
                            }
                        </select>
                    </div>
                    <div style="margin: 0;">
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 8px;">Плановый срок (Дедлайн)</label>
                        <input asp-for="CreateTaskInput.Deadline" type="date" class="form-control" value="@DateTime.UtcNow.AddDays(3).ToString("yyyy-MM-dd")" required style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; outline: none;" />
                    </div>
                </div>
                <div style="padding: 20px 24px; background: #f8fafc; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; gap: 12px; border-radius: 0 0 16px 16px;">
                    <button type="button" class="btn-outline" style="padding: 10px 20px; border-radius: 8px; font-weight: 600; background: white; border: 1px solid #cbd5e1; color: #475569; cursor: pointer;" onclick="document.getElementById('modal-create').classList.remove('open')">Отмена</button>
                    <button type="submit" class="btn-primary" style="background: #3b82f6; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 6px rgba(59, 130, 246, 0.2); transition: background 0.2s;">Назначить задачу</button>
                </div>
            </form>
        </div>
    </div>

    <!-- МОДАЛЬНОЕ ОКНО СПРАВОЧНИКА -->
    <div id="modal-lookup" class="modal-overlay" style="z-index: 3000;">
        <div class="modal-container" style="max-width: 650px; padding: 0; min-height: 450px; display: flex; flex-direction: column;">
            <div class="modal-header" style="background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 16px 20px; display: flex; justify-content: space-between;">
                <h3 id="lookup-title" style="margin: 0; color: #0f172a; display: flex; align-items: center; gap: 8px;"><i data-lucide="database"></i> Системный справочник</h3>
                <button type="button" class="btn-icon" onclick="closeDictionary()" style="background: none; border: none; cursor: pointer;"><i data-lucide="x"></i></button>
            </div>
            <div style="padding: 16px 20px; border-bottom: 1px solid #e2e8f0; background: #f8fafc;">
                <div class="lookup-wrapper" style="background: white; display: flex; align-items: center; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 12px;">
                    <i data-lucide="search" style="color: #94a3b8; width: 18px;"></i>
                    <input type="text" id="lookup-search" class="lookup-input" placeholder="Введите кадастровый номер для фильтрации..." onkeyup="delaySearchDictionary()" autocomplete="off" style="border: none; outline: none; width: 100%; padding: 12px; background: transparent;" />
                </div>
            </div>
            <div style="flex: 1; max-height: 400px; min-height: 250px; overflow-y: auto; background: white; position: relative;">
                <table class="lookup-table" style="width: 100%; border-collapse: collapse;">
                    <thead><tr><th style="font-weight: 600; text-transform: uppercase; text-align: left; padding: 12px 20px; border-bottom: 1px solid #e2e8f0; color: #475569; font-size: 0.8rem; background: #f8fafc;">Результаты поиска в базе геоданных</th></tr></thead>
                    <tbody id="lookup-results"></tbody>
                </table>
                <div id="lookup-loader" style="display: none; padding: 40px 20px; text-align: center; color: #64748b;">
                    <i data-lucide="loader" class="animate-spin" style="margin: 0 auto; width: 28px; height: 28px;"></i>
                    <div style="margin-top: 12px; font-size: 0.95rem;">Выполнение запроса к PostGIS...</div>
                </div>
                <div id="lookup-empty" style="display: none; padding: 40px 20px; text-align: center; color: #94a3b8;">
                    <i data-lucide="inbox" style="margin: 0 auto 12px auto; width: 36px; height: 36px; opacity: 0.5;"></i><br>
                    <span id="lookup-empty-text">Информация по вашему запросу не найдена. Измените критерии поиска.</span>
                </div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        window.INITIAL_DISPATCHER_DATA = @Html.Raw(Model.DispatcherDataJson);

        window.validateInspectionForm = function() {
            var hiddenInput = document.getElementById('wiz-spatial-id');
            if (!hiddenInput.value || hiddenInput.value === '00000000-0000-0000-0000-000000000000') {
                alert('Пожалуйста, выберите целевой участок из системного справочника.');
                return false;
            }
            return true;
        }

        let dictTargetId = '';
        let dictTargetText = '';
        let dictUrl = '';
        let dictSearchTimer = null;

        function openDictionary(url, targetId, targetText, title) {
            dictUrl = url;
            dictTargetId = targetId;
            dictTargetText = targetText;
            document.getElementById('lookup-title').innerHTML = `<i data-lucide="database" style="margin-right:8px; color:#10b981;"></i> ${title}`;
            document.getElementById('lookup-search').value = '';

            const modal = document.getElementById('modal-lookup');
            modal.classList.remove('hidden');
            modal.classList.add('open');

            if (window.lucide) window.lucide.createIcons();
            setTimeout(() => document.getElementById('lookup-search').focus(), 100);
            executeDictionarySearch('');
        }

        function closeDictionary() {
            document.getElementById('modal-lookup').classList.remove('open');
        }

        function delaySearchDictionary() {
            clearTimeout(dictSearchTimer);
            dictSearchTimer = setTimeout(() => {
                executeDictionarySearch(document.getElementById('lookup-search').value);
            }, 300);
        }

        async function executeDictionarySearch(query) {
            const loader = document.getElementById('lookup-loader');
            const empty = document.getElementById('lookup-empty');
            const tbody = document.getElementById('lookup-results');
            loader.style.display = 'block';
            empty.style.display = 'none';
            tbody.innerHTML = '';
            try {
                const fetchUrl = dictUrl + '?q=' + encodeURIComponent(query || '');
                const res = await fetch(fetchUrl);
                if (!res.ok) { const errText = await res.text(); throw new Error(`Код состояния ${res.status}: ${errText}`); }
                const data = await res.json();
                loader.style.display = 'none';
                if (!data || data.length === 0) {
                    empty.style.display = 'block';
                    document.getElementById('lookup-empty-text').innerText = "Информация по вашему запросу не найдена.";
                    return;
                }
                data.forEach(item => {
                    const rawText = item.text ? item.text.toString() : "Идентификатор отсутствует";
                    const safeText = rawText.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
                    const row = document.createElement('tr');
                    row.onclick = () => selectDictionaryItem(item.id, rawText);
                    row.style.cursor = 'pointer';
                    row.style.borderBottom = '1px solid #f1f5f9';
                    row.onmouseover = () => row.style.backgroundColor = '#f8fafc';
                    row.onmouseout = () => row.style.backgroundColor = 'transparent';

                    row.innerHTML = `<td style="padding: 12px 20px;"><div style="display:flex; align-items:center;"><i data-lucide="map-pin" style="width:16px; margin-right:12px; color:#3b82f6; flex-shrink:0;"></i> <span style="white-space: pre-wrap; font-size: 0.9rem; color: #0f172a;">${safeText}</span></div></td>`;
                    tbody.appendChild(row);
                });
                if (window.lucide) window.lucide.createIcons();
            } catch (e) {
                loader.style.display = 'none';
                empty.style.display = 'block';
                document.getElementById('lookup-empty-text').innerHTML = `<span style='color:#ef4444;'>Произошел системный сбой при обращении к API:<br>${e.message}</span>`;
            }
        }

        function selectDictionaryItem(id, text) {
            const inputId = document.getElementById(dictTargetId);
            const inputText = document.getElementById(dictTargetText);
            inputId.value = id;
            inputText.value = text;
            closeDictionary();
        }
    </script>

    <script type="module" src="~/js/inspection/app.js"></script>
}