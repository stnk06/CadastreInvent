                @RenderLookup("Идентификация субъекта", "AddPartyToGroupInput.PartyId", "wiz-member", "/api/registry/lookup/parties", "Системный справочник: Правообладатели")
                <label class="form-label">Пропорция участия в совместном праве</label>
                <div style="display: flex; gap: 16px; align-items: center; margin-bottom: 20px;">
                    <div style="flex: 1;"><input asp-for="AddPartyToGroupInput.ShareNumerator" class="form-control" type="number" min="1" required value="1" placeholder=" " /></div>
                    <div style="font-size: 1.5rem; color: #cbd5e1;">/</div>
                    <div style="flex: 1;"><input asp-for="AddPartyToGroupInput.ShareDenominator" class="form-control" type="number" min="1" required value="1" placeholder=" " /></div>
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn-outline" onclick="closeModal('modal-partygroup-member')">Отменить</button><button type="submit" class="btn-primary">Зарегистрировать</button></div>
        </form>
    </div>
</div>

<div id="modal-baunit-spatial" class="modal-overlay hidden" style="z-index: 1000;">
    <div class="modal-container">
        <form method="post" asp-page-handler="AddSpatialUnitToBAUnit">
            <input type="hidden" name="Tab" value="baunits" />
            <input type="hidden" asp-for="AddSpatialUnitInput.BAUnitId" id="link-spatial-baunit-id" />
            <div class="modal-header"><h3>Установка связи с пространственными координатами</h3><button type="button" class="btn-icon" onclick="closeModal('modal-baunit-spatial')"><i data-lucide="x"></i></button></div>
            <div class="modal-body">
                @RenderLookup("Выбор пространственного контура", "AddSpatialUnitInput.SpatialUnitId", "wiz-spatial", "/api/registry/lookup/spatialunits", "Системный справочник: Пространственные контуры")
            </div>
            <div class="modal-footer"><button type="button" class="btn-outline" onclick="closeModal('modal-baunit-spatial')">Отменить</button><button type="submit" class="btn-primary">Зафиксировать привязку</button></div>
        </form>
    </div>
</div>

<form id="edit-party-form" method="post" asp-page-handler="UpdatePartyContact" class="hidden">
    <input type="hidden" name="id" id="edit-party-id" />
    <input type="hidden" name="contactInfo" id="edit-party-contact" />
    <input type="hidden" name="Tab" value="parties" />
</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.inputmask/5.0.8/jquery.inputmask.min.js"></script>
<script src="~/js/registry-masks.js" asp-append-version="true"></script>
<script src="~/js/inspection/registry-integration.js" asp-append-version="true"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        if (typeof TableHighlighter !== 'undefined') {
            new TableHighlighter('#live-search-input', '#registry-main-table');
        }

        document.getElementById('live-search-input').addEventListener('input', function() {
            const term = this.value.toLowerCase();
            const rows = document.querySelectorAll('#registry-main-table tbody tr');

            rows.forEach(row => {
                const text = row.textContent || row.innerText;
                if (text.toLowerCase().indexOf(term) > -1) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });

    let dictTargetId = '';
    let dictTargetText = '';
    let dictUrl = '';
    let dictSearchTimer = null;

    function openDictionary(url, targetId, targetText, title) {
        dictUrl = url;
        dictTargetId = targetId;
        dictTargetText = targetText;
        document.getElementById('lookup-title').innerHTML = `<i data-lucide="database" style="margin-right:8px; color:#10b981;"></i> ${title}`;
        document.getElementById('lookup-search').value = '';
        document.getElementById('modal-lookup').classList.remove('hidden');
        lucide.createIcons();
        setTimeout(() => document.getElementById('lookup-search').focus(), 100);
        executeDictionarySearch('');
    }

    function closeDictionary() {
        document.getElementById('modal-lookup').classList.add('hidden');
    }

    function delaySearchDictionary() {
        clearTimeout(dictSearchTimer);
        dictSearchTimer = setTimeout(() => {
            executeDictionarySearch(document.getElementById('lookup-search').value);
        }, 300);
    }

    async function executeDictionarySearch(query) {
        const loader = document.getElementById('lookup-loader');
        const empty = document.getElementById('lookup-empty');
        const tbody = document.getElementById('lookup-results');
        loader.style.display = 'block';
        empty.style.display = 'none';
        tbody.innerHTML = '';
        try {
            const fetchUrl = dictUrl + '?q=' + encodeURIComponent(query || '');
            const res = await fetch(fetchUrl);
            if (!res.ok) { const errText = await res.text(); throw new Error(`Код состояния ${res.status}: ${errText}`); }
            const data = await res.json();
            loader.style.display = 'none';
            if (!data || data.length === 0) {
                empty.style.display = 'block';
                document.getElementById('lookup-empty-text').innerText = "Информация по вашему запросу не найдена. Измените критерии поиска.";
                return;
            }
            data.forEach(item => {
                const rawText = item.text ? item.text.toString() : "Идентификатор отсутствует";
                const safeText = rawText.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
                const row = document.createElement('tr');
                row.onclick = () => selectDictionaryItem(item.id, rawText);
                row.style.cursor = 'pointer';
                row.innerHTML = `<td style="padding: 12px 20px; border-bottom: 1px solid #f1f5f9;"><div style="display:flex; align-items:center;"><i data-lucide="file-check" style="width:16px; margin-right:12px; color:#94a3b8; flex-shrink:0;"></i> <span style="white-space: pre-wrap; font-size: 0.9rem;">${safeText}</span></div></td>`;
                tbody.appendChild(row);
            });
            lucide.createIcons();
        } catch (e) {
            loader.style.display = 'none';
            empty.style.display = 'block';
            document.getElementById('lookup-empty-text').innerHTML = `<span style='color:#ef4444;'>Произошел системный сбой при обращении к серверу:<br>${e.message}</span>`;
        }
    }

    function selectDictionaryItem(id, text) {
        const inputId = document.getElementById(dictTargetId);
        const inputText = document.getElementById(dictTargetText);
        inputId.value = id;
        inputText.value = text;
        inputText.setCustomValidity('');
        closeDictionary();
    }

    let currentWizardStep = 1;
    const totalWizardSteps = 3;

    function openWizardModal() {
        currentWizardStep = 1;
        updateWizardUI();
        document.getElementById('modal-wizard').classList.remove('hidden');
    }

    function wizardNext() {
        let stepContent = document.getElementById('step-content-' + currentWizardStep);
        if (currentWizardStep === 1) {
            if (!document.getElementById('wiz-baunit-id').value) { alert("Системное предупреждение: необходимо выбрать объект недвижимости из справочника."); return; }
            if (!document.getElementById('wiz-source-id').value) { alert("Системное предупреждение: необходимо выбрать документальное основание из справочника."); return; }
        }
        else if (currentWizardStep === 2) {
            const type = document.querySelector('input[name="RRRSubjectType"]:checked').value;
            if (type === 'Individual' && !document.getElementById('wiz-party-id').value) { alert("Системное предупреждение: необходимо определить правообладателя через справочник."); return; }
            if (type === 'Group' && !document.getElementById('wiz-group-id').value) { alert("Системное предупреждение: необходимо указать совместное объединение лиц из справочника."); return; }
        }
        let inputs = stepContent.querySelectorAll('input[required], select[required]');
        for(let input of inputs) {
            if (!input.value && input.type !== 'hidden') {
                input.reportValidity();
                return;
            }
        }
        if (currentWizardStep < totalWizardSteps) {
            currentWizardStep++;
            updateWizardUI();
        }
    }

    function wizardPrev() {
        if (currentWizardStep > 1) {
            currentWizardStep--;
            updateWizardUI();
        }
    }

    function updateWizardUI() {
        for(let i=1; i<=totalWizardSteps; i++) {
            let nav = document.getElementById('step-nav-' + i);
            let content = document.getElementById('step-content-' + i);
            nav.classList.remove('active', 'completed');
            if (i < currentWizardStep) nav.classList.add('completed');
            else if (i === currentWizardStep) nav.classList.add('active');
            content.classList.remove('active');
            if (i === currentWizardStep) content.classList.add('active');
        }
        document.getElementById('wiz-btn-prev').style.display = currentWizardStep > 1 ? 'inline-block' : 'none';
        document.getElementById('wiz-btn-next').style.display = currentWizardStep < totalWizardSteps ? 'inline-flex' : 'none';
        document.getElementById('wiz-btn-submit').style.display = currentWizardStep === totalWizardSteps ? 'inline-flex' : 'none';
    }

    function toggleSubjectType(type) {
        if (type === 'Individual') {
            document.getElementById('subject-individual').classList.remove('hidden');
            document.getElementById('subject-group').classList.add('hidden');
            document.getElementById('wiz-group-id').value = '';
            document.getElementById('wiz-group-text').value = '';
        } else {
            document.getElementById('subject-individual').classList.add('hidden');
            document.getElementById('wiz-party-id').value = '';
            document.getElementById('wiz-party-text').value = '';
            document.getElementById('subject-group').classList.remove('hidden');
        }
    }

    function openCreateModal() {
        var tab = '@Model.Tab';
        if (tab === 'baunits') document.getElementById('modal-baunit').classList.remove('hidden');
        else if (tab === 'parties') document.getElementById('modal-party').classList.remove('hidden');
        else if (tab === 'partygroups') document.getElementById('modal-partygroups').classList.remove('hidden');
        else if (tab === 'sources') document.getElementById('modal-sources').classList.remove('hidden');
        else if (tab === 'rrr') openWizardModal();
    }

    function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

    function openTerminateModal(baUnitId, rrrId) {
        document.getElementById('terminate-baunit-id').value = baUnitId;
        document.getElementById('terminate-rrr-id').value = rrrId;
        document.getElementById('modal-rrr-terminate').classList.remove('hidden');
    }

    function openAddMemberModal(groupId) {
        document.getElementById('add-member-group-id').value = groupId;
        document.getElementById('modal-partygroup-member').classList.remove('hidden');
    }

    function openLinkSpatialModal(baUnitId) {
        document.getElementById('link-spatial-baunit-id').value = baUnitId;
        document.getElementById('modal-baunit-spatial').classList.remove('hidden');
    }

    function editParty(id, currentContact) {
        var newContact = prompt("Внесите актуализированные данные для связи (почтовый адрес, телефонные контакты):", currentContact);
        if (newContact !== null && newContact !== currentContact && newContact.trim() !== "") {
            document.getElementById('edit-party-id').value = id;
            document.getElementById('edit-party-contact').value = newContact;
            document.getElementById('edit-party-form').submit();
        }
    }
</script>