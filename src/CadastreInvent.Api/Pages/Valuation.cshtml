@page
@model CadastreInvent.Api.Pages.ValuationModel
@using CadastreInvent.Valuation.Domain.Enums
@{
    ViewData["Title"] = "Массовая кадастровая оценка";
    ViewData["ActivePage"] = "Valuation";
    if (string.IsNullOrEmpty(Model.Tab)) Model.Tab = "dashboard";

    Microsoft.AspNetCore.Html.IHtmlContent RenderLookup(string label, string fieldName, string idPrefix, string url, string dictTitle)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"<div class=\"form-group\">");
        sb.AppendLine($"    <label class=\"form-label\">{label}</label>");
        sb.AppendLine($"    <input type=\"hidden\" name=\"{fieldName}\" id=\"{idPrefix}-id\" />");
        sb.AppendLine($"    <div class=\"lookup-wrapper\">");
        sb.AppendLine($"        <input type=\"text\" id=\"{idPrefix}-text\" class=\"lookup-input\" readonly placeholder=\"Вызвать справочник...\" onclick=\"openDictionary('{url}', '{idPrefix}-id', '{idPrefix}-text', '{dictTitle}')\" />");
        sb.AppendLine($"        <button type=\"button\" class=\"lookup-btn\" onclick=\"openDictionary('{url}', '{idPrefix}-id', '{idPrefix}-text', '{dictTitle}')\"><i data-lucide=\"search\" style=\"width: 16px;\"></i></button>");
        sb.AppendLine($"    </div>");
        sb.AppendLine($"</div>");
        return Html.Raw(sb.ToString());
    }
}
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/valuation-modals.css" asp-append-version="true" />
<style>
    .filter-panel {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        padding: 16px;
        background: #ffffff;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .table-search {
        position: relative;
        flex: 1 1 auto;
        min-width: 250px;
    }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        z-index: 10;
    }

    .search-input {
        width: 100%;
        padding: 8px 16px 8px 38px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
        background: #ffffff;
        color: #0f172a;
        box-sizing: border-box;
        transition: all 0.2s;
    }

        .search-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .dash-card {
        background: white;
        padding: 24px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: var(--shadow-soft);
        display: flex;
        flex-direction: column;
    }

    .dash-value {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-top: 8px;
    }

    .dash-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .btn-outline:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        border-color: #cbd5e1 !important;
        color: #64748b !important;
    }

    .btn-primary:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        background: #94a3b8 !important;
        border-color: #94a3b8 !important;
        box-shadow: none !important;
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Массовая кадастровая оценка (CAMA)</h1>
        <p class="page-subtitle">Обучение нейросетей, учет ценообразующих факторов и обработка оспариваний стоимости</p>
    </div>
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap; justify-content: flex-end;">
        @if (Model.Tab == "models")
        {
            <form method="post" asp-page-handler="Train" style="margin: 0;">
                <button type="submit" class="btn-primary" onclick="return confirm('Запустить обучение модели? В случае обнаружения мусорных сделок, они будут заблокированы.');">
                    <i data-lucide="brain-circuit"></i> Обучить новую модель
                </button>
            </form>
        }
        else if (Model.Tab == "units")
        {
            <button class="btn-primary" onclick="openModal('modal-unit-create')">
                <i data-lucide="plus"></i> Поставить на оценку
            </button>
        }
        else if (Model.Tab == "sales")
        {
            <button class="btn-primary" onclick="openModal('modal-sale')">
                <i data-lucide="plus"></i> Внести сделку в реестр цен
            </button>
        }
        else if (Model.Tab == "appeals")
        {
            <button class="btn-primary" onclick="openModal('modal-appeal-create')">
                <i data-lucide="scale"></i> Зарегистрировать апелляцию
            </button>
        }
    </div>
</div>

<div class="tabs" style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px; padding-bottom: 8px;">
    <a href="/Valuation?tab=dashboard" class="tab-link @(Model.Tab == "dashboard" ? "active" : "")"><i data-lucide="layout-dashboard" style="width:16px; margin-right:6px;"></i>Аналитика</a>
    <a href="/Valuation?tab=models" class="tab-link @(Model.Tab == "models" ? "active" : "")">Модели оценки</a>
    <a href="/Valuation?tab=units" class="tab-link @(Model.Tab == "units" ? "active" : "")">Объекты</a>
    <a href="/Valuation?tab=sales" class="tab-link @(Model.Tab == "sales" ? "active" : "")">Реестр сделок</a>
    <a href="/Valuation?tab=results" class="tab-link @(Model.Tab == "results" ? "active" : "")">Результаты оценки</a>
    <a href="/Valuation?tab=appeals" class="tab-link @(Model.Tab == "appeals" ? "active" : "")">Оспаривание</a>
    <a href="/Valuation?tab=diagnostics" class="tab-link @(Model.Tab == "diagnostics" ? "active" : "")" style="background:#fef2f2; color:#b91c1c; border-color:#fecaca;"><i data-lucide="terminal" style="width:16px; margin-right:6px;"></i>Live-Терминал</a>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info" style="@(Model.StatusMessage.Contains("Ошибка") || Model.StatusMessage.Contains("Сбой") ? "background: #fef2f2; color: #991b1b; border-color: #fecaca;" : "background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe;")">
        <i data-lucide="@(Model.StatusMessage.Contains("Ошибка") || Model.StatusMessage.Contains("Сбой") ? "alert-triangle" : "info")" style="width: 18px; height: 18px; display: inline-block; vertical-align: middle; margin-right: 8px;"></i>
        <span style="vertical-align: middle;">@Model.StatusMessage</span>
    </div>
}

@if (Model.Tab == "diagnostics")
{
    <partial name="Shared/_DiagnosticsTerminal" />
}
else if (Model.Tab == "dashboard")
{
    <div id="dash-loading" style="padding: 40px; text-align: center; color: #64748b;">
        <i data-lucide="loader" class="animate-spin" style="width: 32px; height: 32px; margin-bottom: 16px;"></i>
        <div>Сбор аналитики движка CAMA...</div>
    </div>

    <div id="dash-content" class="dashboard-grid" style="display: none;">
        <div class="dash-card">
            <div style="display:flex; justify-content: space-between; align-items:flex-start;">
                <div class="dash-title">Готовность к ML Обучению</div>
                <div id="dash-ready-icon"></div>
            </div>
            <div class="dash-value" id="dash-sales-count">0 <span style="font-size: 1rem; color: #64748b; font-weight: normal;">/ 10 мин. сделок</span></div>
            <p id="dash-sales-text" style="font-size: 0.85rem; margin-top: 12px; color: #475569;"></p>
        </div>

        <div class="dash-card">
            <div style="display:flex; justify-content: space-between; align-items:flex-start;">
                <div class="dash-title">Текущая ML Модель</div>
                <div id="dash-model-badge"></div>
            </div>
            <div class="dash-value" id="dash-model-version" style="font-size: 1.5rem;">Загрузка...</div>
            <div id="dash-model-metrics" style="margin-top: 12px; font-size: 0.85rem; background: #f8fafc; padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0;"></div>
        </div>

        <div class="dash-card">
            <div style="display:flex; justify-content: space-between; align-items:flex-start;">
                <div class="dash-title">Статистика Реестра</div>
                <i data-lucide="database" style="color: #3b82f6;"></i>
            </div>
            <div style="margin-top: 16px; display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px;">
                    <span style="color: #64748b; font-size: 0.9rem;">Объектов на учете:</span>
                    <strong id="dash-total-units" style="color: #0f172a;">0</strong>
                </div>
                <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
                    <span style="color: #64748b; font-size: 0.9rem;">Рассчитанных оценок:</span>
                    <strong id="dash-total-vals" style="color: #0f172a;">0</strong>
                </div>
            </div>
        </div>
    </div>

    <div style="background: white; padding: 16px; border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 24px; box-shadow: var(--shadow-soft);">
        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
            <span style="font-weight: 600; color: #0f172a;"><i data-lucide="cpu" style="width:16px;height:16px;vertical-align:middle;margin-right:8px;color:#3b82f6;"></i>Индикатор фоновой оценки</span>
            <span id="mass-appraisal-text" style="font-weight: 700; color: #3b82f6;">Ожидание...</span>
        </div>
        <div style="width: 100%; background: #e2e8f0; border-radius: 8px; height: 12px; overflow: hidden;">
            <div id="mass-appraisal-bar" style="width: 0%; background: #3b82f6; height: 100%; transition: width 0.4s ease-in-out;"></div>
        </div>
    </div>
}
else
{
    <div class="table-container">
        <div class="filter-panel">
            <div class="table-search">
                <i data-lucide="search" class="search-icon" style="color: #3b82f6; width: 18px; height: 18px;"></i>
                <input type="text" id="api-search-input" class="search-input" placeholder="Поиск в базе данных сервера..." autocomplete="off" />
            </div>

            @if (Model.Tab == "units")
            {
                <select id="api-filter-select" class="filter-input" style="flex: 0 1 auto;">
                    <option value="">Все зоны территориального покрытия</option>
                    <option value="Residential">ИЖС (Жилая зона)</option>
                    <option value="Commercial">Коммерция</option>
                    <option value="Industrial">Индустриальная зона</option>
                    <option value="Agricultural">Агропромышленность</option>
                </select>
            }
            else if (Model.Tab == "sales")
            {
                <select id="api-filter-select" class="filter-input" style="flex: 0 1 auto;">
                    <option value="">Любые транзакции</option>
                    <option value="ValidMarket">Достоверные рыночные сделки</option>
                    <option value="InvalidAffiliated">Аффилированные сделки (Исключены)</option>
                    <option value="InvalidForeclosure">Реализация залогов (Исключены)</option>
                    <option value="InvalidOutlier">Статистические выбросы (Исключены)</option>
                </select>
            }
            else if (Model.Tab == "results")
            {
                <select id="api-filter-select" class="filter-input" style="flex: 0 1 auto;">
                    <option value="">Все методики вычисления</option>
                    <option value="AutomatedMachineLearning">Массовая (CAMA)</option>
                    <option value="Comparative">Индивидуальная (Сравнительная)</option>
                </select>
            }
            else if (Model.Tab == "appeals")
            {
                <select id="api-filter-select" class="filter-input" style="flex: 0 1 auto;">
                    <option value="">Все статусы производств</option>
                    <option value="Submitted">Первичное заявление</option>
                    <option value="UnderReview">Анализ комиссией</option>
                    <option value="Resolved">Акт удовлетворен</option>
                    <option value="Rejected">Отказ в удовлетворении</option>
                    <option value="CourtDispute">Судебное производство</option>
                </select>
            }
            <button class="btn-outline" style="padding: 6px 12px; font-size: 0.8rem;" onclick="resetApiFilters()">Сбросить</button>
        </div>

        <div class="table-responsive">
            <table id="valuation-main-table">
                <thead>
                    <tr>
                        @if (Model.Tab == "models")
                        {
                            <th>Спецификация алгоритма</th>
                            <th>Детализация и Метрики</th>
                            <th>Дата фиксации</th>
                            <th style="text-align:right;">Управление</th>
     }
                        else if (Model.Tab == "units")
                        {
                            <th>Объект</th>
                            <th>Зонирование</th>
                            <th>Характеристики</th>
                            <th style="text-align:right;">Операции</th>
     }
                        else if (Model.Tab == "sales")
                        {
                            <th>Объект</th>
                            <th>Стоимость</th>
                            <th>Дата</th>
                            <th>Статус</th>
                            <th style="text-align:right;">Управление</th>
     }
                        else if (Model.Tab == "results")
                        {
                            <th>Объект</th>
                            <th>Зона</th>
                            <th>Стоимость</th>
                            <th>Алгоритм</th>
                            <th>Модель</th>
                            <th style="text-align:right;">Хронология</th>
     }
                        else if (Model.Tab == "appeals")
                        {
                            <th>Объект / Заявитель</th>
                            <th>Претензия</th>
                            <th>Текущая цена</th>
                            <th>Статус</th>
                            <th style="text-align:right;">Решение</th>
     }
                    </tr>
                </thead>
                <tbody id="valuation-tbody"><tr><td colspan="6" style="text-align:center; padding: 40px; color: #94a3b8;">Загрузка...</td></tr></tbody>
            </table>
        </div>
        <div style="padding: 16px 24px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; background: #f8fafc;">
            <div style="font-size: 0.85rem; color: #64748b;" id="pagination-info">Загрузка системной информации...</div>
            <div style="display: flex; gap: 8px;" id="pagination-buttons"></div>
        </div>
    </div>
}

<!-- МОДАЛКИ ДЛЯ CRUD ОПЕРАЦИЙ -->
<div id="modal-appraisal-wizard" class="modal-overlay hidden" style="z-index: 1000;">
    <div class="modal-container" style="max-width: 650px;">
        <form method="post" id="appraisal-wizard-form" asp-page-handler="ExecuteAppraisal">
            <input type="hidden" name="Tab" value="results" />
            <input type="hidden" asp-for="ExecuteAppraisalInput.ModelId" id="wiz-model-id" />
            <div class="modal-header" style="background: #0f172a; color: white;">
                <h3 style="display: flex; align-items: center; gap: 8px;"><i data-lucide="cpu" style="color: #10b981;"></i> Ассистент массовой оценки</h3>
                <button type="button" class="btn-icon" onclick="closeModal('modal-appraisal-wizard')" style="color: white;"><i data-lucide="x"></i></button>
            </div>
            <div class="modal-body" style="background: #f8fafc;">
                <div class="wizard-nav">
                    <div class="wizard-step active" id="appr-step-nav-1"><div class="wizard-circle">1</div><div class="wizard-label">Алгоритм ML</div></div>
                    <div class="wizard-step" id="appr-step-nav-2"><div class="wizard-circle">2</div><div class="wizard-label">Фильтрация</div></div>
                    <div class="wizard-step" id="appr-step-nav-3"><div class="wizard-circle">3</div><div class="wizard-label">Запуск процесса</div></div>
                </div>
                <div class="wizard-content active" id="appr-step-content-1">
                    <div style="background: white; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-soft);">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Выбранная математическая модель</label>
                            <input type="text" id="wiz-model-text" class="form-control" readonly style="background: #e2e8f0; color: #475569; font-weight: 600;" />
                        </div>
                    </div>
                </div>
                <div class="wizard-content" id="appr-step-content-2">
                    <div style="background: white; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-soft);">
                        <div class="form-group">
                            <label class="form-label">Ограничение по зоне покрытия (Опционально)</label>
                            <select asp-for="ExecuteAppraisalInput.ZoningStatusFilter" class="form-control" style="background: white;">
                                <option value="">Без территориальных ограничений (Весь реестр)</option>
                                <option value="Residential">ИЖС (Жилая застройка)</option>
                                <option value="Commercial">Коммерческая зона</option>
                                <option value="Industrial">Промышленная зона</option>
                                <option value="Agricultural">Сельхозназначение</option>
                            </select>
                        </div>
                        <div style="display: flex; gap: 16px;">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Минимальная площадь (от)</label>
                                <input asp-for="ExecuteAppraisalInput.MinArea" type="number" step="0.1" min="0" class="form-control" placeholder="0.0" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Максимальная площадь (до)</label>
                                <input asp-for="ExecuteAppraisalInput.MaxArea" type="number" step="0.1" min="0" class="form-control" placeholder="Не ограничено" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="wizard-content" id="appr-step-content-3">
                    <div style="background: white; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-soft);">
                        <div class="alert alert-info" style="margin: 0;">
                            <i data-lucide="info" style="width: 20px; height: 20px; float: left; margin-right: 12px;"></i>
                            <strong>Внимание!</strong> Фоновый расчет приведет к генерации тысяч транзакций в базе данных. Старые оценки сохранятся в историческом срезе, а новые станут актуальными немедленно по завершении процесса.
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline" id="appr-wiz-btn-prev" onclick="appraisalWizardPrev()" style="display: none;">Предыдущий этап</button>
                <button type="button" class="btn-primary" id="appr-wiz-btn-next" onclick="appraisalWizardNext()">Продолжить конфигурацию <i data-lucide="arrow-right" style="margin-left: 8px; margin-right: 0;"></i></button>
                <button type="submit" class="btn-primary" id="appr-wiz-btn-submit" style="display: none; background: #10b981; box-shadow: 0 4px 12px rgba(16,185,129,0.3);"><i data-lucide="play" style="margin-right: 8px;"></i> Инициировать процессинг</button>
            </div>
        </form>
    </div>
</div>

<div id="modal-unit-create" class="modal-overlay hidden" style="z-index: 1000;">
    <div class="modal-container">
        <form method="post" asp-page-handler="CreateValuationUnit">
            <input type="hidden" name="Tab" value="units" />
            <div class="modal-header">
                <h3>Постановка объекта на учет для оценки</h3>
                <button type="button" class="btn-icon" onclick="closeModal('modal-unit-create')"><i data-lucide="x"></i></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Связанный объект недвижимости</label>
                    <select asp-for="CreateUnitInput.BAUnitId" class="form-control" required>
                        @foreach (var b in Model.AvailableBAUnits)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Зона территориального зонирования</label>
                    <select asp-for="CreateUnitInput.ZoningStatus" class="form-control" required>
                        <option value="Residential">ИЖС (Жилая застройка)</option>
                        <option value="Commercial">Коммерческая зона</option>
                        <option value="Industrial">Промышленная зона</option>
                        <option value="Agricultural">Сельхозназначение</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline" onclick="closeModal('modal-unit-create')">Отмена</button>
                <button type="submit" class="btn-primary">Создать профиль оценки</button>
            </div>
        </form>
    </div>
</div>

<div id="modal-zoning-edit" class="modal-overlay hidden" style="z-index: 1000;">
    <div class="modal-container">
        <form method="post" asp-page-handler="UpdateZoning">
            <input type="hidden" name="Tab" value="units" />
            <input type="hidden" asp-for="UpdateZoningInput.ValuationUnitId" id="zoning-unit-id" />
            <div class="modal-header">
                <h3>Изменение территориальной зоны</h3>
                <button type="button" class="btn-icon" onclick="closeModal('modal-zoning-edit')"><i data-lucide="x"></i></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Новая зона</label>
                    <select asp-for="UpdateZoningInput.ZoningStatus" id="zoning-status-select" class="form-control" required>
                        <option value="Residential">ИЖС (Жилая застройка)</option>
                        <option value="Commercial">Коммерческая зона</option>
                        <option value="Industrial">Промышленная зона</option>
                        <option value="Agricultural">Сельхозназначение</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline" onclick="closeModal('modal-zoning-edit')">Отмена</button>
                <button type="submit" class="btn-primary">Применить</button>
            </div>
        </form>
    </div>
</div>

<div id="modal-char-edit" class="modal-overlay hidden" style="z-index: 1000;">
