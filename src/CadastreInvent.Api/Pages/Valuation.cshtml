<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    let apiCurrentPage = 1;
    const apiPageSize = 25;
    const currentTab = '@Model.Tab';
    let globalSignalRConnection = null;

    document.addEventListener("DOMContentLoaded", function() {
        initSignalR();
        if (currentTab === 'dashboard') loadDashboardStats();
        else if (currentTab === 'diagnostics') fetchDiagnosticHistory();
        else fetchAndRenderTable();
    });

    function initSignalR() {
        if (globalSignalRConnection) return;

        globalSignalRConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/mass-appraisal")
            .withAutomaticReconnect()
            .build();

        globalSignalRConnection.on("AppraisalProgress", (data) => {
            const bar = document.getElementById('mass-appraisal-bar');
            const text = document.getElementById('mass-appraisal-text');

            if (data.total > 0 && bar && text) {
                const percent = Math.round((data.processed / data.total) * 100);
                bar.style.width = percent + '%';
                text.innerText = percent + '% (' + data.processed + ' / ' + data.total + ')';

                if (data.status === 'completed') {
                    bar.style.background = '#10b981';
                    setTimeout(() => window.location.reload(), 2000);
                } else {
                    bar.style.background = '#3b82f6';
                }
            }
        });

        globalSignalRConnection.on("ReceiveDiagnosticLog", (log) => {
            if (typeof appendLogToTerminal === "function") {
                appendLogToTerminal(log);
            }
        });

        globalSignalRConnection.start().catch(err => console.error("SignalR Connection Error: ", err));
    }

    function loadDashboardStats() {
        fetch('/api/Valuation/dashboard-stats')
            .then(r => r.json())
            .then(data => {
                document.getElementById('dash-loading').style.display = 'none';
                document.getElementById('dash-content').style.display = 'grid';

                document.getElementById('dash-sales-count').innerHTML = `${data.validSales} <span style="font-size: 1rem; color: #64748b; font-weight: normal;">/ 10 мин. сделок</span>`;
                if (data.isReadyForTraining) {
                    document.getElementById('dash-ready-icon').innerHTML = '<i data-lucide="check-circle" style="color: #10b981; width: 24px; height: 24px;"></i>';
                    document.getElementById('dash-sales-text').innerHTML = '<span style="color: #10b981; font-weight: 600;">Готово к обучению.</span> Вы можете запустить сборку модели.';
                } else {
                    document.getElementById('dash-ready-icon').innerHTML = '<i data-lucide="alert-triangle" style="color: #ef4444; width: 24px; height: 24px;"></i>';
                    document.getElementById('dash-sales-text').innerHTML = '<span style="color: #ef4444; font-weight: 600;">Недостаточно данных.</span> Добавьте рыночные сделки. Система блокирует обучение (защита от мусора).';
                }

                document.getElementById('dash-model-version').innerText = data.activeModelVersion;
                if (data.activeModelStatus === 'Active') {
                    document.getElementById('dash-model-badge').innerHTML = '<span class="badge" style="background:#dcfce7; color:#166534; border:1px solid #bbf7d0;">Работает</span>';
                } else if (data.activeModelStatus.startsWith('Failed') || data.activeModelStatus.startsWith('TrainingFailed')) {
                    document.getElementById('dash-model-badge').innerHTML = `<span class="badge" style="background:#fee2e2; color:#991b1b; border:1px solid #fecaca;">Брак</span>`;
                } else {
                    document.getElementById('dash-model-badge').innerHTML = `<span class="badge" style="background:#f1f5f9; color:#475569; border:1px solid #cbd5e1;">${data.activeModelStatus}</span>`;
                }

                document.getElementById('dash-total-units').innerText = data.totalUnits;
                document.getElementById('dash-total-vals').innerText = data.totalValuations;

                try {
                    if (data.activeModelMetrics && data.activeModelMetrics !== "{}") {
                        const m = JSON.parse(data.activeModelMetrics);
                        document.getElementById('dash-model-metrics').innerHTML = `
                            <div style="display:flex; justify-content:space-between; margin-bottom:4px;"><span>Точность (R²):</span> <strong>${m.RSquared ? (m.RSquared * 100).toFixed(1) + '%' : 'N/A'}</strong></div>
                            <div style="display:flex; justify-content:space-between;"><span>Ср. ошибка (MAPE):</span> <strong>${m.Mape ? (m.Mape * 100).toFixed(1) + '%' : 'N/A'}</strong></div>
                        `;
                    } else {
                        document.getElementById('dash-model-metrics').innerHTML = '<span style="color:#94a3b8;">Метрики качества отсутствуют</span>';
                    }
                } catch(e) {}
                if (window.lucide) window.lucide.createIcons();
            })
            .catch(e => console.error(e));
    }

    let searchTimer = null;
    const searchInput = document.getElementById('api-search-input');
    if (searchInput) {
        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => { apiCurrentPage = 1; fetchAndRenderTable(); }, 400);
        });
    }

    const filterSelect = document.getElementById('api-filter-select');
    if (filterSelect) {
        filterSelect.addEventListener('change', () => { apiCurrentPage = 1; fetchAndRenderTable(); });
    }

    function resetApiFilters() {
        if(document.getElementById('api-search-input')) document.getElementById('api-search-input').value = '';
        if (filterSelect) filterSelect.value = '';
        apiCurrentPage = 1;
        fetchAndRenderTable();
    }

    function escHtml(str) {
        if (!str) return '';
        return str.toString().replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function fetchAndRenderTable() {
        if (currentTab === 'dashboard' || currentTab === 'diagnostics') return;

        const searchInput = document.getElementById('api-search-input');
        const search = searchInput ? searchInput.value : '';
        const filterSelect = document.getElementById('api-filter-select');
        let filter = filterSelect ? filterSelect.value : '';

        const tbody = document.getElementById('valuation-tbody');
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding: 40px; color: #94a3b8;"><i data-lucide="loader" class="animate-spin" style="margin-bottom:8px;"></i><br>Загрузка данных по сети...</td></tr>';
        if (window.lucide) window.lucide.createIcons();

        fetch(`/api/Valuation/list/${currentTab}?page=${apiCurrentPage}&pageSize=${apiPageSize}&search=${encodeURIComponent(search)}&filterType=${encodeURIComponent(filter)}`)
            .then(r => r.json())
            .then(data => {
                if (data.items.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding: 40px; color: #94a3b8;"><i data-lucide="inbox" style="margin-bottom:8px; opacity: 0.5; width: 32px; height: 32px;"></i><br>Системные данные отсутствуют</td></tr>`;
                } else {
                    let html = '';
                    data.items.forEach(item => {
                        if (currentTab === 'models') html += renderModelRow(item);
                        else if (currentTab === 'units') html += renderUnitRow(item);
                        else if (currentTab === 'sales') html += renderSaleRow(item);
                        else if (currentTab === 'results') html += renderResultRow(item);
                        else if (currentTab === 'appeals') html += renderAppealRow(item);
                    });
                    tbody.innerHTML = html;
                }

                const totalPages = Math.ceil(data.total / apiPageSize);
                document.getElementById('pagination-info').innerText = data.total > 0
                    ? `Отображаются записи ${((apiCurrentPage - 1) * apiPageSize) + 1} - ${Math.min(apiCurrentPage * apiPageSize, data.total)} из совокупного массива ${data.total}`
                    : `Системные данные отсутствуют`;

                const btnHtml = `
                    <button class="btn-outline" style="padding: 6px 12px; font-size: 0.8rem;" ${apiCurrentPage <= 1 ? 'disabled' : ''} onclick="apiCurrentPage--; fetchAndRenderTable();">Предыдущая</button>
                    <button class="btn-outline" style="padding: 6px 12px; font-size: 0.8rem;" ${apiCurrentPage >= totalPages ? 'disabled' : ''} onclick="apiCurrentPage++; fetchAndRenderTable();">Следующая</button>
                `;
                document.getElementById('pagination-buttons').innerHTML = btnHtml;

                if (window.lucide) window.lucide.createIcons();
            })
            .catch(e => {
                tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding: 40px; color: #ef4444;"><i data-lucide="alert-triangle" style="margin-bottom:8px;"></i><br>Ошибка связи с сервером</td></tr>`;
                if (window.lucide) window.lucide.createIcons();
            });
    }

    // SOFT DELETE: Скрывает модель в архив
    function deleteModel(id) {
        if (!confirm('Вы уверены, что хотите скрыть эту модель в Архив? Исторические оценки, рассчитанные ей, останутся в системе.')) return;

        fetch(`/api/Valuation/models/${id}`, { method: 'DELETE' })
            .then(res => {
                if (!res.ok) throw new Error('Ошибка перемещения модели в архив. Сервер вернул код ' + res.status);
                fetchAndRenderTable();
            })
            .catch(err => alert(err.message));
    }

    function renderModelRow(item) {
        const dateStr = new Date(item.trainingDate).toLocaleString('ru-RU', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});

        let isFailed = item.status !== 'Active';
        let statusBadge = '';

        if (!isFailed) {
            statusBadge = '<span class="badge" style="background:#dcfce7; color:#166534; border:1px solid #bbf7d0;">Активна (Успешно)</span>';
        } else {
            let readableStatus = item.status;
            if (item.status === 'TrainingFailed_LowAccuracy') readableStatus = 'Низкая точность';
            if (item.status === 'Failed_OutliersDetected') readableStatus = 'Аномалии данных (IQR)';
            if (item.status === 'Failed_InsufficientData') readableStatus = 'Мало данных';
            if (item.status === 'Failed_CorruptedJson') readableStatus = 'Ошибка JSON';

            statusBadge = `<span class="badge" style="background:#fee2e2; color:#991b1b; border:1px solid #fecaca;">Брак: ${readableStatus}</span>`;
        }

        let metricsHtml = '';
        try {
            if (item.metrics && item.metrics !== "{}") {
                const m = JSON.parse(item.metrics);
                if (m.RSquared !== undefined) {
                     metricsHtml = `<div style="font-size: 0.8rem; background: #f8fafc; padding: 4px 8px; border-radius: 4px; display: inline-block; border: 1px solid #e2e8f0; margin-bottom: 4px;">R²: <strong>${(m.RSquared*100).toFixed(1)}%</strong> | MAPE: <strong>${(m.Mape*100).toFixed(1)}%</strong></div>`;
                }
            }
        } catch(e) {}

        let reasonHtml = '';
        if (isFailed) {
            reasonHtml = `<div style="font-size: 0.75rem; color: #b91c1c; background: #fef2f2; padding: 6px 8px; border-radius: 4px; border-left: 3px solid #ef4444; margin-top: 4px; line-height: 1.4;"><strong>Причина:</strong> ${escHtml(item.description)}</div>`;
        } else {
            reasonHtml = `<div style="font-size: 0.75rem; color: #64748b; margin-top: 4px;">${escHtml(item.description)}</div>`;
        }

        let actionsHtml = `
            <button class="btn-outline" style="border-color: #3b82f6; color: #3b82f6; padding: 6px 10px; display:flex; align-items:center; gap:6px;" onclick="openAppraisalWizard('${item.id}', '${escHtml(item.version)}')" ${isFailed ? 'disabled title="Модель забракована, запуск невозможен"' : ''}>
                <i data-lucide="play" style="width: 14px;"></i> Запуск
            </button>
            <button class="btn-icon" style="color: #ef4444; background: #fef2f2; border: 1px solid #fecaca; padding: 6px;" title="Скрыть модель в архив" onclick="deleteModel('${item.id}')">
                <i data-lucide="archive" style="width: 16px; height: 16px;"></i>
            </button>
        `;

        return `<tr>
            <td style="vertical-align: top;">
                <div class="td-flex">
                    <div class="td-icon" style="background: #e0f2fe; color: #0284c7;"><i data-lucide="cpu"></i></div>
                    <div>
                        <div class="td-title">${escHtml(item.version)}</div>
                        <div class="td-subtitle" style="font-family: monospace;">Ядро: ${escHtml(item.algorithm)}</div>
                    </div>
                </div>
            </td>
            <td style="max-width: 400px;">
                <div style="margin-bottom: 6px;">${statusBadge}</div>
                ${metricsHtml}
                ${reasonHtml}
            </td>
            <td style="vertical-align: top;"><span class="badge" style="background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1;">${dateStr}</span></td>
            <td style="vertical-align: top;">
                <div style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                    ${actionsHtml}
                </div>
            </td>
        </tr>`;
    }

    function renderUnitRow(item) {
        let charsHtml = '';
        if (item.parsedCharacteristics) {
            charsHtml = `<div style="display: flex; flex-wrap: wrap; gap: 6px; max-width: 350px;">`;
            for(const [key, value] of Object.entries(item.parsedCharacteristics)) {
                charsHtml += `<span style="background: #f1f5f9; border: 1px solid #e2e8f0; color: #475569; font-size: 0.75rem; padding: 4px 8px; border-radius: 6px;"><span style="color: #94a3b8;">${escHtml(key)}:</span> <span style="font-weight: 600; color: #0f172a;">${escHtml(value)}</span></span>`;
            }
            charsHtml += `</div>`;
        } else {
            charsHtml = `<span style="color: #ef4444; font-size: 0.8rem; font-weight: 500;"><i data-lucide="alert-circle" style="width: 14px; vertical-align: sub;"></i> Характеристики не заданы</span>`;
        }
        const jsonEscaped = item.characteristicsJson ? item.characteristicsJson.replace(/'/g, "\\'") : '';
        return `<tr>
            <td>
                <div class="td-flex">
                    <div class="td-icon" style="background: #e0f2fe; color: #0369a1;"><i data-lucide="map-pin"></i></div>
                    <div>
                        <div class="td-title">${escHtml(item.baUnitName)}</div>
                        <div class="td-subtitle" style="font-family: monospace;">Код учета: ${item.id.substring(0, 8)}</div>
                    </div>
                </div>
            </td>
            <td><span class="badge" style="background: #f8fafc; color: #334155; border: 1px solid #e2e8f0;">${escHtml(item.zoningStatus)}</span></td>
            <td>${charsHtml}</td>
            <td style="text-align: right; white-space: nowrap;">
                <button class="btn-icon" title="Обновить профиль зонирования" onclick="openZoningModal('${item.id}', '${escHtml(item.zoningStatus)}')"><i data-lucide="layers"></i></button>
                <button class="btn-icon" title="Редактировать матрицу характеристик" onclick="openCharacteristicsModal('${item.id}', '${item.characteristicsId || ''}', '${jsonEscaped}')"><i data-lucide="sliders"></i></button>
            </td>
        </tr>`;
    }

    function renderSaleRow(item) {
        const isInvalid = item.validity !== 'ValidMarket';
        const dateStr = new Date(item.transactionDate).toLocaleString('ru-RU', {day:'2-digit',month:'2-digit',year:'numeric'});
        const priceStr = item.salePrice.toLocaleString('ru-RU');

        let validityText = item.validity;
        if (item.validity === 'InvalidOutlier') validityText = 'Аномалия (IQR-фильтр)';
        if (item.validity === 'InvalidAffiliated') validityText = 'Аффилированность';
        if (item.validity === 'InvalidForeclosure') validityText = 'Залог/Банкротство';

        let badgeHtml = isInvalid
            ? `<span class="badge" style="background: #fee2e2; color: #991b1b; border: 1px solid #fecaca;"><i data-lucide="shield-alert" style="width:12px; margin-right:4px;"></i>Брак: ${validityText}</span>`
            : `<span class="badge" style="background: #dcfce7; color: #166534; border: 1px solid #bbf7d0;"><i data-lucide="check-circle" style="width:12px; margin-right:4px;"></i>Рыночная (Достоверная)</span>`;

        let actionHtml = isInvalid
            ? `<span style="font-size: 0.8rem; color: #94a3b8;">Исключена из ML</span>`
            : `<button class="btn-outline" style="border-color: #ef4444; color: #ef4444; padding: 4px 8px; font-size: 0.75rem;" onclick="openInvalidateModal('${item.id}')">Выбраковать вручную</button>`;

        return `<tr style="${isInvalid ? 'opacity: 0.6; background: #f8fafc;' : ''}">
            <td>
                <div class="td-title">${escHtml(item.baUnitName)}</div>
                <div class="td-subtitle" style="font-family: monospace;">Индекс: ${item.valuationUnitId.substring(0, 8)}</div>
            </td>
            <td style="font-weight: 800; color: #166534; font-size: 1.1rem;">${priceStr} ₽</td>
            <td style="font-size: 0.9rem;">${dateStr}</td>
            <td>${badgeHtml}</td>
            <td style="text-align: right;">${actionHtml}</td>
        </tr>`;
    }

    function renderResultRow(item) {
        const priceStr = item.assessedValue.toLocaleString('ru-RU');
        const dateStr = new Date(item.valuationDate).toLocaleString('ru-RU', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
        const methodHtml = item.method === 'AutomatedMachineLearning'
            ? `<span style="color: #3b82f6; font-weight: 600;"><i data-lucide="cpu" style="width: 14px; vertical-align: sub;"></i> CAMA Engine</span>`
            : `<span style="color: #f59e0b; font-weight: 600;"><i data-lucide="user" style="width: 14px; vertical-align: sub;"></i> Ручная корректировка</span>`;

        return `<tr>
            <td>
                <div class="td-title">${escHtml(item.baUnitName)}</div>
                <div class="td-subtitle" style="font-family: monospace;">Код учета: ${item.id.substring(0, 8)}</div>
            </td>
            <td><span class="badge" style="background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1;">${escHtml(item.zoningStatus)}</span></td>
            <td style="font-weight: 800; color: #0f172a; font-size: 1.2rem;">${priceStr} ₽</td>
            <td>${methodHtml}</td>
            <td>
                <div style="font-size: 0.85rem; color: #0f172a;">${escHtml(item.modelVersion)}</div>
                <div style="font-size: 0.75rem; color: #64748b;">${dateStr}</div>
            </td>
            <td style="text-align: right; white-space: nowrap;">
                <button class="btn-outline" style="padding: 6px 12px; font-size: 0.8rem;" onclick="openHistoryModal('${item.id}')">
                    <i data-lucide="history" style="width: 14px;"></i> Журнал
                </button>
            </td>
        </tr>`;
    }

    function renderAppealRow(item) {
        const priceStr = item.currentAssessedValue.toLocaleString('ru-RU');
        let badgeHtml = '';
        if (item.status === 'Submitted') badgeHtml = `<span class="badge" style="background: #fef08a; color: #92400e; border: 1px solid #fde047;">Регистрация</span>`;
        else if (item.status === 'UnderReview') badgeHtml = `<span class="badge" style="background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd;">В комиссии</span>`;
        else if (item.status === 'Resolved') badgeHtml = `<span class="badge" style="background: #dcfce7; color: #166534; border: 1px solid #bbf7d0;">Удовлетворено</span>`;
        else if (item.status === 'Rejected') badgeHtml = `<span class="badge" style="background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1;">Отклонено</span>`;
        else badgeHtml = `<span class="badge" style="background: #fee2e2; color: #991b1b; border: 1px solid #fecaca;">Судебное производство</span>`;

        let actionHtml = (item.status === 'Submitted' || item.status === 'UnderReview')
            ? `<button class="btn-outline" style="padding: 6px 12px; font-size: 0.8rem;" onclick="openAppealModal('${item.id}', '${item.currentAssessedValue}')">Рассмотреть</button>`
            : '';

        return `<tr>
            <td>
                <div class="td-flex">
                    <div class="td-icon" style="background: #fef3c7; color: #d97706;"><i data-lucide="scale"></i></div>
                    <div>
                        <div class="td-title">${escHtml(item.baUnitName)}</div>
                        <div class="td-subtitle">Субъект: ${escHtml(item.applicantName)}</div>
                    </div>
                </div>
            </td>
            <td style="font-size: 0.85rem; color: #475569; max-width: 250px; white-space: normal;">${escHtml(item.reason)}</td>
            <td style="font-weight: 700; color: #0f172a;">${priceStr} ₽</td>
            <td>${badgeHtml}</td>
            <td style="text-align: right;">${actionHtml}</td>
        </tr>`;
    }

    // --- Обработчики специфичных кнопок ---
    function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
    function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

    function openZoningModal(unitId, currentZone) {
        document.getElementById('zoning-unit-id').value = unitId;
        document.getElementById('zoning-status-select').value = currentZone;
        openModal('modal-zoning-edit');
    }

    function openCharacteristicsModal(unitId, charId, jsonString) {
        document.getElementById('char-unit-id').value = unitId;
        document.getElementById('char-char-id').value = charId || '';

        document.getElementById('char-area').value = '';
        document.getElementById('char-year').value = '';
        document.getElementById('char-floor').value = '';
        document.getElementById('char-distance').value = '';
        document.getElementById('char-rooms').value = '';

        if (jsonString) {
            try {
                const data = JSON.parse(jsonString);
                document.getElementById('char-area').value = data.Area || '';
                document.getElementById('char-year').value = data.YearBuilt || '';
                document.getElementById('char-floor').value = data.Floor || '';
                document.getElementById('char-distance').value = data.DistanceToCenterKm || '';
                document.getElementById('char-rooms').value = data.RoomsCount || '';
            } catch (e) { console.error('JSON Parse error', e); }
        }
        openModal('modal-char-edit');
    }

    function syncJson() {
        const data = {
            Area: parseFloat(document.getElementById('char-area').value) || null,
            YearBuilt: parseFloat(document.getElementById('char-year').value) || null,
            Floor: parseFloat(document.getElementById('char-floor').value) || null,
            DistanceToCenterKm: parseFloat(document.getElementById('char-distance').value) || null,
            RoomsCount: parseFloat(document.getElementById('char-rooms').value) || null
        };
        const jsonString = JSON.stringify(data);

        const isUpdate = !!document.getElementById('char-char-id').value;
        if (isUpdate) {
            document.getElementById('char-json-update-hidden').value = jsonString;
            document.getElementById('char-json-add-hidden').value = '';
            document.getElementById('char-form').action = '?handler=UpdateCharacteristic';
        } else {
            document.getElementById('char-json-add-hidden').value = jsonString;
            document.getElementById('char-json-update-hidden').value = '';
            document.getElementById('char-form').action = '?handler=AddCharacteristic';
        }
    }

    function openInvalidateModal(id) {
        document.getElementById('invalidate-sale-id').value = id;
        openModal('modal-sale-invalidate');
    }

    function openAppealModal(id, currentPrice) {
        document.getElementById('appeal-id-input').value = id;
        document.getElementById('appeal-new-price-input').value = currentPrice;
        toggleNewPriceInput();
        openModal('modal-appeal-resolve');
    }

    function toggleNewPriceInput() {
        const status = document.getElementById('appeal-status-select').value;
        const container = document.getElementById('new-price-container');
        if (status === 'Resolved') {
            container.style.display = 'block';
            document.getElementById('appeal-new-price-input').required = true;
        } else {
            container.style.display = 'none';
            document.getElementById('appeal-new-price-input').required = false;
        }
    }

    function openHistoryModal(id) {
        openModal('modal-valuation-history');
        document.getElementById('history-loader').style.display = 'block';
        document.getElementById('history-timeline').innerHTML = '';

        fetch('/api/Valuation/valuations/' + id + '/history')
            .then(res => res.json())
            .then(data => {
                document.getElementById('history-loader').style.display = 'none';
                let html = '';
                if (data.length === 0) {
                    html = '<div style="text-align: center; color: #94a3b8; padding: 20px;">История пуста</div>';
                } else {
                    data.forEach(item => {
                        const from = new Date(item.validFrom).toLocaleString('ru-RU');
                        const to = item.isCurrent ? "По настоящее время" : new Date(item.validTo).toLocaleString('ru-RU');
                        const badge = item.isCurrent ? '<span class="badge badge-success">Актуально</span>' : '<span class="badge" style="background:#f1f5f9;">Архив</span>';
                        const methodText = item.method === 'AutomatedMachineLearning' ? 'ML.NET CAMA Engine' : 'Индивидуальная ручная оценка';

                        html += `
                            <div style="background: white; padding: 16px; border: 1px solid #e2e8f0; border-radius: 8px; border-left: 4px solid ${item.isCurrent ? '#10b981' : '#cbd5e1'};">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                                    <div style="font-weight: 700; color: #0f172a; font-size: 1.1rem;">${item.assessedValue.toLocaleString('ru-RU')} ₽</div>
                                    <div>${badge}</div>
                                </div>
                                <div style="font-size: 0.85rem; color: #64748b;">
                                    <i data-lucide="cpu" style="width: 14px; vertical-align: text-bottom;"></i> ${methodText}<br/>
                                    <i data-lucide="clock" style="width: 14px; vertical-align: text-bottom; margin-top: 4px;"></i> ${from} &mdash; ${to}
                                </div>
                            </div>
                        `;
                    });
                }
                document.getElementById('history-timeline').innerHTML = html;
                lucide.createIcons();
            })
            .catch(err => {
                document.getElementById('history-loader').style.display = 'none';
                document.getElementById('history-timeline').innerHTML = '<div style="color: #ef4444; text-align: center;">Ошибка загрузки истории</div>';
            });
    }

    // --- Логика Wizard для Массовой Оценки ---
    let apprCurrentWizardStep = 1;
    const apprTotalWizardSteps = 3;

    function openAppraisalWizard(modelId, version) {
        document.getElementById('wiz-model-id').value = modelId;
        document.getElementById('wiz-model-text').value = version;
        apprCurrentWizardStep = 1;
        updateAppraisalWizardUI();
        openModal('modal-appraisal-wizard');
    }

    function appraisalWizardNext() {
        let stepContent = document.getElementById('appr-step-content-' + apprCurrentWizardStep);
        let inputs = stepContent.querySelectorAll('input[required], select[required]');
        for (let input of inputs) {
            if (!input.value && input.type !== 'hidden') {
                input.reportValidity();
                return;
            }
        }
        if (apprCurrentWizardStep < apprTotalWizardSteps) {
            apprCurrentWizardStep++;
            updateAppraisalWizardUI();
        }
    }

    function appraisalWizardPrev() {
        if (apprCurrentWizardStep > 1) {
            apprCurrentWizardStep--;
            updateAppraisalWizardUI();
        }
    }

    function updateAppraisalWizardUI() {
        for (let i = 1; i <= apprTotalWizardSteps; i++) {
            let nav = document.getElementById('appr-step-nav-' + i);
            let content = document.getElementById('appr-step-content-' + i);
            nav.classList.remove('active', 'completed');
            if (i < apprCurrentWizardStep) nav.classList.add('completed');
            else if (i === apprCurrentWizardStep) nav.classList.add('active');
            content.classList.remove('active');
            if (i === apprCurrentWizardStep) content.classList.add('active');
        }
        document.getElementById('appr-wiz-btn-prev').style.display = apprCurrentWizardStep > 1 ? 'inline-block' : 'none';
        document.getElementById('appr-wiz-btn-next').style.display = apprCurrentWizardStep < apprTotalWizardSteps ? 'inline-flex' : 'none';
        document.getElementById('appr-wiz-btn-submit').style.display = apprCurrentWizardStep === apprTotalWizardSteps ? 'inline-flex' : 'none';
    }

    // --- Системный справочник (Lookup) ---
    let dictTargetId = '';
    let dictTargetText = '';
    let dictUrl = '';
    let dictSearchTimer = null;

    function openDictionary(url, targetId, targetText, title) {
        dictUrl = url;
        dictTargetId = targetId;
        dictTargetText = targetText;
        document.getElementById('lookup-title').innerHTML = `<i data-lucide="database" style="margin-right:8px; color:#10b981;"></i> ${title}`;
        document.getElementById('lookup-search').value = '';
        openModal('modal-lookup');
        lucide.createIcons();
        setTimeout(() => document.getElementById('lookup-search').focus(), 100);
        executeDictionarySearch('');
    }

    function closeDictionary() {
        closeModal('modal-lookup');
    }

    function delaySearchDictionary() {
        clearTimeout(dictSearchTimer);
        dictSearchTimer = setTimeout(() => {
            executeDictionarySearch(document.getElementById('lookup-search').value);
        }, 300);
    }

    async function executeDictionarySearch(query) {
        const loader = document.getElementById('lookup-loader');
        const empty = document.getElementById('lookup-empty');
        const tbody = document.getElementById('lookup-results');
        loader.style.display = 'block';
        empty.style.display = 'none';
        tbody.innerHTML = '';
        try {
            const fetchUrl = dictUrl + '?q=' + encodeURIComponent(query || '');
            const res = await fetch(fetchUrl);
            if (!res.ok) { const errText = await res.text(); throw new Error(`Код состояния ${res.status}: ${errText}`); }
            const data = await res.json();
            loader.style.display = 'none';
            if (!data || data.length === 0) {
                empty.style.display = 'block';
                document.getElementById('lookup-empty-text').innerText = "Информация по вашему запросу не найдена. Измените критерии поиска.";
                return;
            }
            data.forEach(item => {
                const rawText = item.text ? item.text.toString() : "Идентификатор отсутствует";
                const safeText = rawText.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
                const row = document.createElement('tr');
                row.onclick = () => selectDictionaryItem(item.id, rawText);
                row.style.cursor = 'pointer';
                row.innerHTML = `<td style="padding: 12px 20px; border-bottom: 1px solid #f1f5f9;"><div style="display:flex; align-items:center;"><i data-lucide="file-check" style="width:16px; margin-right:12px; color:#94a3b8; flex-shrink:0;"></i> <span style="white-space: pre-wrap; font-size: 0.9rem;">${safeText}</span></div></td>`;
                tbody.appendChild(row);
            });
            lucide.createIcons();
        } catch (e) {
            loader.style.display = 'none';
            empty.style.display = 'block';
            document.getElementById('lookup-empty-text').innerHTML = `<span style='color:#ef4444;'>Произошел системный сбой при обращении к серверу:<br>${e.message}</span>`;
        }
    }

    function selectDictionaryItem(id, text) {
        const inputId = document.getElementById(dictTargetId);
        const inputText = document.getElementById(dictTargetText);
        inputId.value = id;
        inputText.value = text;
        inputText.setCustomValidity('');
        closeDictionary();
    }
</script>